# ── AI Provider ────────────────────────────────────────────────────────────────
# Set AI_PROVIDER to "claude" (default) or "openai".
# If not set, the app auto-detects: uses Claude if ANTHROPIC_API_KEY is present,
# otherwise falls back to OpenAI if OPENAI_API_KEY is present.
AI_PROVIDER=claude

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Optional: override the default OpenAI model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Required for OTP sign-in emails. Get your key at https://resend.com
# Without this, the app runs in dev mode and only logs OTPs to the console.
RESEND_API_KEY=re_...

# Optional: override the sender address (must be a verified Resend domain)
# EMAIL_FROM=Landing Page Advisor <noreply@yourdomain.com>
